{
  "expo": {
    "name": "Montra",
    "slug": "expensetracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "expensetracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "Personal finance tracker with AI insights, savings goals, and investment watchlist.",
    "primaryColor": "#6366F1",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.montra.expensetracker",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Montra uses the camera to scan receipts and add expense details automatically.",
        "NSPhotoLibraryUsageDescription": "Montra accesses your photo library so you can upload receipt images and profile photos.",
        "NSMicrophoneUsageDescription": "Montra uses the microphone so you can speak to the AI assistant with voice commands.",
        "NSSpeechRecognitionUsageDescription": "Montra uses speech recognition to convert your voice into text for the AI assistant.",
        "UIBackgroundModes": ["remote-notification"]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    "android": {
      "package": "com.montra.expensetracker",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES",
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Montra accesses your photos to upload receipts and profile pictures.",
          "cameraPermission": "Montra uses the camera to scan receipts for expense tracking."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6366F1",
          "defaultChannel": "budget-alerts",
          "sounds": []
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Montra uses the microphone for voice chat with the AI assistant."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-web-browser",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
